DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_room?schema=public"

AI_PROVIDER=deepseek

# ---- 共享网关（OpenAI 兼容协议），gpt/gemini/grok/qwen 可复用 ----
LLM_GATEWAY_API_KEY=
LLM_GATEWAY_BASE_URL=https://api.chatanywhere.tech/v1

# ---- DeepSeek 官方 ----
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 以下变量按需启用：留空则该 provider 沿用 LLM_GATEWAY_* 的 key 和 base
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini

# GEMINI_API_KEY=
# GEMINI_BASE_URL=
# GEMINI_MODEL=gemini-2.0-flash

# GROK_API_KEY=
# GROK_BASE_URL=
# GROK_MODEL=grok-2-latest

# QWEN_API_KEY=
# QWEN_BASE_URL=
# QWEN_MODEL=qwen-plus

AI_PROVIDER_TIMEOUT_MS=30000
AI_PROVIDER_MAX_TOKENS=600
AI_PROVIDER_MOCK_FALLBACK=true